{
  "name": "theia-standard",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "theia build",
    "start": "theia start --hostname 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "@theia/application-package": "1.50.0",
    "@theia/core": "1.50.0",
    "@theia/workspace": "1.50.0",
    "@theia/filesystem": "1.50.0",
    "@theia/navigator": "1.50.0",
    "@theia/terminal": "1.50.0",
    "@theia/output": "1.50.0",
    "@theia/markers": "1.50.0",
    "@theia/task": "1.50.0",
    "@theia/search-in-workspace": "1.50.0",
    "@theia/file-search": "1.50.0",
    "@theia/git": "1.50.0",
    "@theia/scm": "1.50.0",
    "@theia/editor": "1.50.0",
    "@theia/monaco": "1.50.0",
    "@theia/preferences": "1.50.0",
    "@theia/plugin-ext": "1.50.0",
    "@theia/plugin-ext-vscode": "1.50.0",
    "@theia/vsx-registry": "1.50.0"
  },
  "devDependencies": {
    "@theia/cli": "1.50.0",
    "@theia/webpack": "1.50.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^4.0.0"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "Theia IDE",
        "defaultTheme": "dark",
        "preferences": {
          "workbench.colorTheme": "Dark (Theia)",
          "editor.fontLigatures": true,
          "files.autoSave": "onFocusChange",
          "terminal.integrated.defaultProfile.linux": "bash"
        }
      }
    }
  },
  "theiaPluginsDir": "plugins"
}