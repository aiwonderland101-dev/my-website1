{
  "name": "unreal-wonder-build",
  "version": "0.1.0",
  "main": "./src/UnrealWonderBuildPage.tsx",
  "types": "./src/UnrealWonderBuildPage.tsx",
  "dependencies": {
    "playcanvas": "^2.17.0"
  },
  "scripts": {
    "verify:logic": "node scripts/verify_logic.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm run verify:logic && pnpm run typecheck"
  },
  "puckIntegration": {
    "requiredPackages": [
      "@puckeditor/plugin-ai",
      "@puckeditor/cloud-client",
      "zod"
    ],
    "registryStatus": "blocked_403_requires_credentials",
    "installCommands": [
      "pnpm add @puckeditor/plugin-ai",
      "pnpm add @puckeditor/cloud-client",
      "pnpm add zod"
    ]
  }
}
