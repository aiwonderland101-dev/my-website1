{
  "version": "1.0",
  "name": "ai_confessions_policy",
  "rules": [
    {
      "id": "no-secrets",
      "description": "Block or redact API keys, tokens, private keys, and other secret-like patterns.",
      "patterns": [
        "sk-[A-Za-z0-9-_]{20,}",
        "AIza[0-9A-Za-z-_]{35}",
        "-----BEGIN PRIVATE KEY-----",
        "-----BEGIN RSA PRIVATE KEY-----"
      ],
      "action": "sanitize"
    },
    {
      "id": "no-pii",
      "description": "Redact emails, phone numbers, SSNs, and addresses.",
      "patterns": [
        "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}",
        "\\b\\d{3}[-.]?\\d{2}[-.]?\\d{4}\\b",  
        "\\b\\+?\\d{7,15}\\b",
        "\\b\\d{1,5}\\s+[A-Za-z0-9.\\s]{3,30}\\b"
      ],
      "action": "sanitize"
    },
    {
      "id": "no-harm",
      "description": "Block content that instructs illegal or unsafe actions.",
      "patterns": ["bomb", "harm", "illegal", "buy weapons"],
      "action": "block"
    }
  ],
  "audit": {
    "logBlocked": true,
    "logPath": "logs/ai_policy_blocked.log"
  }
}
