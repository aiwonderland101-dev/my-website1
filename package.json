{
  "name": "ai-wonderland",
  "private": true,
  "workspaces": [
    "WonderSpace",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --filter !ai-wonderland dev",
    "build": "pnpm -r --filter !ai-wonderland build",
    "test": "vitest run",
    "test:watch": "vitest",
    "swarm:unreal": "node scripts/swarm/run-unreal-stack.mjs",
    "registry:sync": "node scripts/registry/sync-assets.mjs",
    "registry:sync:dry": "node scripts/registry/sync-assets.mjs --dry-run"
  },
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@next/swc-linux-x64-gnu": "^16.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tiptap/extension-superscript": "^3.20.4"
  }
}
